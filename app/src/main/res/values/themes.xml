<resources>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">

        <item name="windowSplashScreenBackground">@color/main</item>

        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>

        <item name="postSplashScreenTheme">@style/AppTheme</item>

    </style>

    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">

        <item name="colorPrimary">@color/main</item>

        <item name="colorSecondary">@color/main</item>

        <item name="colorTertiary">?android:attr/textColorPrimary</item>

        <item name="android:statusBarColor">@android:color/transparent</item>

        <item name="android:navigationBarColor">@android:color/transparent</item>

        <item name="android:textColorSecondary">@color/black</item>

        <item name="windowNoTitle">true</item>

        <item name="popupTheme">@style/PopupTheme</item>

    </style>

    <style name="PopupTheme" parent="AppTheme">

        <item name="android:popupBackground">@color/white</item>

        <item name="android:textColorPrimary">@color/black</item>

    </style>

    <style name="ToolbarTheme" parent="AppTheme">

        <item name="android:background">@color/toolbar_background</item>

        <item name="android:textColorPrimary">@color/white</item>

        <item name="android:textColorSecondary">@color/white</item>

    </style>

    <style name="PreferenceTheme" parent="AppTheme">

        <item name="colorAccent">@color/main</item>

        <item name="android:windowBackground">@color/white</item>

    </style>

    <style name="StatusTheme" parent="AppTheme">

        <item name="android:background">@color/white</item>

    </style>

    <style name="AuthorTheme" parent="AppTheme">

        <item name="android:background">@color/white</item>

    </style>

    <style name="PermissionTheme" parent="AppTheme">

        <item name="android:background">@color/white</item>

    </style>

    <style name="PingTheme" parent="AppTheme">

        <item name="android:background">@color/white</item>

    </style>

</resources>

